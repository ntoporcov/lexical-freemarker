{
  "name": "@mininic-nt/lexical-freemarker",
  "version": "0.1.0",
  "description": "Lexical plugins that wrap Freemarker templating functionality.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "workspaces": [
    "apps/tester"
  ],
  "scripts": {
    "build:lib": "tsup src/index.ts --format esm,cjs --dts",
    "build:tester": "npm run build --workspace @mininic-nt/lexical-freemarker-tester",
    "build": "npm run build:lib && npm run build:tester",
    "dev:lib": "tsup src/index.ts --format esm,cjs --dts --watch",
    "dev:tester": "npm run dev --workspace @mininic-nt/lexical-freemarker-tester",
    "typecheck": "tsc --noEmit -p tsconfig.json && npm run typecheck --workspace @mininic-nt/lexical-freemarker-tester",
    "lint": "npm run typecheck",
    "test": "node ./scripts/run-tests.mjs",
    "test:changed": "node ./scripts/test-changed.mjs",
    "prepare": "node ./scripts/setup-git-hooks.mjs",
    "prepublishOnly": "npm run build:lib"
  },
  "keywords": [
    "lexical",
    "freemarker",
    "plugin",
    "templating"
  ],
  "author": "",
  "license": "UNLICENSED",
  "peerDependencies": {
    "lexical": "^0.24.0"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  }
}
